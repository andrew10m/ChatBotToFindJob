# Telegram Bot Token
BOT_TOKEN="YOUR_TELEGRAM_BOT_TOKEN_HERE"

# Database URL (for SQLite, this is the file path)
# For PostgreSQL, it would be something like: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL="job_bot.db"

# Comma-separated list of Telegram User IDs for administrators
ADMIN_IDS="123456789,987654321"

# Redis settings (optional, for FSM scaling)
# REDIS_HOST="localhost"
# REDIS_PORT="6379"
